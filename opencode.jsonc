{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "grep *": "allow",
    "find *": "allow",
    "xargs": "allow",
  },
  "mcp": {
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
    },
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "git add*": "allow",
          "git checkout*": "allow",
          "git commit*": "allow",
          "git diff*": "allow",
          "git stash*": "allow",
          "git status*": "allow",
          "npm *": "allow",
          "npm install -g *": "ask",
          "npx *": "allow",
        },
      },
    },
  },
}
